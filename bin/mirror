#!/usr/bin/env python3
import subprocess
import sys
import datetime
import os
import re
from rich.console import Console
from rich.table import Table
from rich.panel import Panel
from rich.align import Align
from rich import box

# --- CONFIGURATION ---
LEDGER_FILE = os.path.expanduser("~/Documents/finance/2026.journal")
CURRENCY = "NGN"

console = Console()


def get_expenses():
    """Get sorted expenses for the dashboard."""
    cmd = [
        "hledger",
        "-f",
        LEDGER_FILE,
        "bal",
        "expenses",
        "-p",
        "this month",
        "--depth",
        "2",  # Depth 2 ensures we see 'Food:Street' not just 'Food'
        "--no-total",
        "-O",
        "csv",
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return result.stdout.strip().split("\n")
    except subprocess.CalledProcessError:
        return []


def parse(rows):
    expenses = []
    for line in rows:
        if "account" in line or not line:
            continue

        parts = line.replace('"', "").split(",")
        if len(parts) < 2:
            continue

        account = parts[0]
        raw_amount = parts[1]

        # Regex to keep only numbers and decimals
        clean_amount = re.sub(r"[^\d.]", "", raw_amount)

        try:
            amount = float(clean_amount)
            if amount > 1.0:  # Filter out tiny noise
                expenses.append((account, amount))
        except ValueError:
            continue

    return sorted(expenses, key=lambda x: x[1], reverse=True)


def main():
    if not os.path.exists(LEDGER_FILE):
        console.print("[red]Journal not found.[/red]")
        return

    data = parse(get_expenses())
    total_spent = sum(x[1] for x in data)

    if not data:
        console.print(Panel("No movement this month.", style="green"))
        return

    # Dashboard Table
    table = Table(box=box.ROUNDED, show_header=True, border_style="blue")
    table.add_column("Category", style="cyan")
    table.add_column("Amount", justify="right", style="bold white")
    table.add_column("%", justify="right", style="dim")

    for account, amount in data:
        # Format: Expenses:Food:Street -> Food ➤ Street
        clean_name = account.replace("Expenses:", "").replace(":", " [dim]➤[/dim] ")
        percent = (amount / total_spent) * 100

        table.add_row(clean_name, f"{amount:,.2f}", f"{percent:.1f}%")

    # Footer
    footer = f"[bold]TOTAL:[/bold] [bold red]{CURRENCY} {total_spent:,.2f}[/bold red]"

    console.print("\n")
    console.print(
        Align.center(
            Panel.fit(
                f"[b]FORTRESS MIRROR[/b]\n[dim]{datetime.datetime.now().strftime('%B')}[/dim]",
                border_style="white",
            )
        )
    )
    console.print(Align.center(table))
    console.print(Align.center(footer))
    console.print("\n")


if __name__ == "__main__":
    main()
