#!/usr/bin/env bash

# ==============================================================================
#  GET - The Universal Downloader (Aria2c Wrapper)
#  Handles single links, batch files, and session resuming.
# ==============================================================================

# --- COLORS ---
GREEN='\033[1;32m'
BLUE='\033[1;34m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

SESSION_FILE="$HOME/.aria2_session"

# --- HELPER FUNCTIONS ---

# sanitize_url: Fixes spaces, brackets, etc. using Python
sanitize_url() {
  python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=':/?=&'))" "$1"
}

# sanitize_batch: Reads file, ignores comments, cleans URLs
sanitize_batch() {
  local input="$1"
  local output="$2"
  python3 -c "
import urllib.parse, sys
with open('$input', 'r') as f:
    for line in f:
        line = line.strip()
        if not line or line.startswith('#'): continue
        print(urllib.parse.quote(line, safe=':/?=&'))
" >"$output"
}

# --- MODES ---

mode_single() {
  local raw_url="$1"
  local url=$(sanitize_url "$raw_url")

  echo -e "${BLUE}>>> [get] Target:${NC} $url"

  aria2c --continue=true \
    --max-connection-per-server=16 \
    --split=16 \
    --min-split-size=1M \
    --seed-time=0 \
    --user-agent="Mozilla/5.0" \
    --save-session="$SESSION_FILE" \
    --save-session-interval=60 \
    "$url"
}

mode_batch() {
  local input="$1"
  if [ ! -f "$input" ]; then
    echo -e "${RED}Error: File '$input' not found.${NC}"
    exit 1
  fi

  local clean_list="/tmp/aria2_batch_clean.txt"
  echo -e "${BLUE}>>> [get] Processing batch file:${NC} $input"

  sanitize_batch "$input" "$clean_list"
  local count=$(wc -l <"$clean_list")
  echo -e "${GREEN}>>> Found $count valid links.${NC}"

  aria2c --input-file="$clean_list" \
    --max-concurrent-downloads=4 \
    --max-connection-per-server=16 \
    --split=16 \
    --min-split-size=1M \
    --user-agent="Mozilla/5.0" \
    --seed-time=0 \
    --save-session="$SESSION_FILE" \
    --save-session-interval=60

  rm "$clean_list"
}

mode_resume() {
  if [ ! -f "$SESSION_FILE" ]; then
    echo -e "${RED}Error: No session file found at $SESSION_FILE${NC}"
    exit 1
  fi

  echo -e "${YELLOW}>>> [get] Resuming previous session...${NC}"
  aria2c --input-file="$SESSION_FILE" \
    --save-session="$SESSION_FILE" \
    --save-session-interval=60
}

usage() {
  echo -e "${BLUE}Usage:${NC} get [flags] <target>"
  echo "  <url>           Download a single URL"
  echo "  -b <file.txt>   Batch download from a text file"
  echo "  -r              Resume incomplete downloads from session"
  exit 1
}

# --- MAIN ROUTER ---

if [ -z "$1" ]; then
  usage
fi

case "$1" in
-b | --batch)
  if [ -z "$2" ]; then
    echo "Missing file argument."
    exit 1
  fi
  mode_batch "$2"
  ;;
-r | --resume)
  mode_resume
  ;;
-h | --help)
  usage
  ;;
*)
  # Default: Treat as single URL
  # Check if user accidentally typed 'get -b' without file
  if [[ "$1" == -* ]]; then
    echo -e "${RED}Unknown option: $1${NC}"
    usage
  fi
  mode_single "$1"
  ;;
esac
