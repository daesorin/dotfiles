#!/usr/bin/env bash

# ==============================================================================
#  CURRENCY - Financial Intelligence Tool
#  Real-time conversion for Crypto (BTC) and Fiat (NGN/USD/EUR/etc).
# ==============================================================================

# --- COLORS & STYLING ---
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
RED='\033[1;31m'
NC='\033[0m'
BOLD='\033[1m'

# --- DEPENDENCY CHECK ---
check_deps() {
  for cmd in jq bc curl; do
    if ! command -v $cmd &>/dev/null; then
      echo -e "${RED}Error: '$cmd' is missing.${NC}"
      echo "Install it via: sudo pacman -S $cmd"
      exit 1
    fi
  done
}

# --- FORMATTING HELPER ---
# Adds commas to numbers (e.g. 1000000 -> 1,000,000.00)
fmt_num() {
  local num=$1
  local decimals=${2:-2}
  printf "%'.${decimals}f" "$num"
}

# --- MODULE: BITCOIN ADDRESS SCANNER ---
scan_btc() {
  local addr="$1"
  echo -e "${BLUE}🔍 Scanning Bitcoin Address...${NC}"

  # 1. Get Balance in Sats (Mempool API)
  local sats=$(curl -s "https://mempool.space/api/address/$addr" | jq '.chain_stats.funded_txo_sum - .chain_stats.spent_txo_sum')

  if [[ "$sats" == "null" || -z "$sats" ]]; then
    echo -e "${RED}❌ Invalid address or API error.${NC}"
    return 1
  fi

  # 2. Get Price in NGN (CoinGecko API)
  local rate=$(curl -s "https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=ngn" | jq '.bitcoin.ngn')

  # 3. Calculate Value (Sats -> BTC -> NGN)
  local val=$(echo "scale=2; $sats * $rate / 100000000" | bc -l)

  # Output
  echo "-----------------------------------"
  echo -e "💰 Balance:   ${GREEN}$(fmt_num $sats 0) sats${NC}"
  echo -e "📈 Rate:      ${YELLOW}₦$(fmt_num $rate 2) / BTC${NC}"
  echo -e "🇳🇬 Value:     ${GREEN}₦$(fmt_num $val 2)${NC}"
  echo "-----------------------------------"
}

# --- MODULE: FIAT TO NGN (e.g. 'usd 50' -> NGN) ---
to_ngn() {
  # Normalize input: "currency 50 usd" OR "currency usd 50"
  if [[ "$1" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    local amount="$1"
    local code="${2:-USD}"
  else
    local code="${1:-USD}"
    local amount="${2:-1}"
  fi

  local target=$(echo "$code" | tr '[:lower:]' '[:upper:]')

  echo -e "${BLUE}🔍 Fetching $target rate...${NC}"

  # Fetch Rate
  local data=$(curl -s "https://open.er-api.com/v6/latest/$target")
  local rate=$(echo "$data" | jq '.rates.NGN')

  if [[ "$rate" == "null" ]]; then
    echo -e "${RED}❌ Currency '$target' not found.${NC}"
    return 1
  fi

  # Calculate
  local val=$(echo "$amount * $rate" | bc -l)

  # Output
  echo "-----------------------------------"
  echo -e "💱 Pair:      ${BOLD}$target / NGN${NC}"
  echo -e "📈 Rate:      ${YELLOW}₦$(fmt_num $rate)${NC}"
  echo -e "💵 Value:     ${GREEN}₦$(fmt_num $val)${NC}  (${target} $(fmt_num $amount 0))"
  echo "-----------------------------------"
}

# --- MODULE: NGN TO FIAT (e.g. 'to usd 5000' -> USD) ---
from_ngn() {
  local code="${1:-USD}"
  local amount="${2:-1}"
  local target=$(echo "$code" | tr '[:lower:]' '[:upper:]')

  echo -e "${BLUE}🔍 Converting ₦$(fmt_num $amount 0) to $target...${NC}"

  # Fetch Rate (Base NGN)
  local data=$(curl -s "https://open.er-api.com/v6/latest/NGN")
  local rate=$(echo "$data" | jq ".rates.$target")

  if [[ "$rate" == "null" ]]; then
    echo -e "${RED}❌ Currency '$target' not found.${NC}"
    return 1
  fi

  # Math: Handle small rates (crypto/weak currencies)
  local rate_decimal=$(printf "%.10f" "$rate")
  local val=$(echo "$amount * $rate_decimal" | bc -l)

  # Output
  echo "-----------------------------------"
  echo -e "📉 Rate:      1 NGN = $rate_decimal $target"
  echo -e "💵 Result:    ${GREEN}$target $(fmt_num $val)${NC}"
  echo "-----------------------------------"
}

# --- MAIN EXECUTION ---
check_deps

# Default to help if no args
if [[ -z "$1" ]]; then
  echo -e "${CYAN}Currency Tool${NC}"
  echo "Usage:"
  echo "  currency <amount> <code>    ${YELLOW}Convert Foreign -> NGN${NC} (e.g. currency 50 usd)"
  echo "  currency to <code> <amt>    ${YELLOW}Convert NGN -> Foreign${NC} (e.g. currency to usd 5000)"
  echo "  currency btc <address>      ${YELLOW}Check Bitcoin Wallet Value${NC}"
  exit 1
fi

case "$1" in
btc)
  if [[ -z "$2" ]]; then
    echo -e "${RED}Error: Missing address.${NC} Usage: currency btc <address>"
    exit 1
  fi
  scan_btc "$2"
  ;;
to)
  if [[ -z "$2" ]]; then
    echo -e "${RED}Error: Missing code.${NC} Usage: currency to usd 5000"
    exit 1
  fi
  from_ngn "$2" "$3"
  ;;
*)
  # Default behavior: Foreign -> NGN
  to_ngn "$1" "$2"
  ;;
esac
