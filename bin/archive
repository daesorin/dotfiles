#!/usr/bin/env bash

# ==============================================================================
#  ARCHIVE v2.1 - Intelligent Media Downloader
#  Real-time format scanning, Resume persistence, and History tracking.
# ==============================================================================

# --- LOCATIONS ---
DIR_VIDEO="$HOME/Videos"
DIR_MUSIC="$HOME/Music"
HIST_VIDEO="$HOME/.config/archive_history_video.txt"
HIST_MUSIC="$HOME/.config/archive_history_music.txt"

# --- COLORS ---
GREEN='\033[1;32m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
GREY='\033[0;90m'
NC='\033[0m'

# --- CONFIGURATION ---
# -c: Force resume of partially downloaded files
# --no-mtime: Don't set file modification time (helps with sorting by download date)
BASE_ARGS=(
  "--quiet" "--progress"
  "-c"
  "--no-warnings"
  "--ignore-errors"
  "--add-metadata"
  "--embed-thumbnail"
  "--embed-subs"
  "--sub-langs" "all,-live_chat"
  "--embed-chapters"
  "--no-mtime"
)

# --- DEPENDENCY CHECK ---
check_deps() {
  for cmd in yt-dlp ffmpeg fzf awk; do
    if ! command -v "$cmd" &>/dev/null; then
      echo -e "${RED}Error: '$cmd' is missing.${NC}"
      exit 1
    fi
  done
  # Create history files if missing
  mkdir -p "$(dirname "$HIST_VIDEO")"
  touch "$HIST_VIDEO" "$HIST_MUSIC"
}

# --- FUNCTIONS ---

# 1. Scan URL for specific formats
scan_and_select() {
  local url="$1"

  echo -e "${CYAN}🔍 Scanning available formats...${NC}"

  # Fetch formats, remove header lines, and pipe to FZF
  # We capture the raw output first to handle errors
  if ! raw_formats=$(yt-dlp -F "$url" 2>/dev/null); then
    echo -e "${RED}Failed to fetch formats. URL might be invalid.${NC}"
    exit 1
  fi

  # Present the menu
  # We assume the user wants the best at the bottom, so we use --tac (reverse)
  # We extract the first column (Format ID) using awk
  selected_line=$(echo "$raw_formats" | grep -v "format code" | grep -v "\[info\]" |
    fzf --height=60% --layout=reverse --border --prompt="🎥 Select Quality > " \
      --header="ID  EXT  RES  FPS  SIZE  BITRATE  CODECS" \
      --color="header:blue,info:yellow,pointer:cyan")

  if [[ -z "$selected_line" ]]; then
    echo -e "${YELLOW}Selection cancelled.${NC}"
    exit 0
  fi

  # Extract the ID (first column)
  local f_id
  f_id=$(echo "$selected_line" | awk '{print $1}')

  # Check if it's "audio only" (often ID 140, 251, etc) or video
  # If the line contains "audio only", treat differently?
  # Actually, yt-dlp handles merging automatically if we use the right flag structure.

  echo -e "${GREEN}✅ Selected ID: $f_id${NC}"
  dl_specific "$url" "$f_id"
}

# 2. Download Specific Format (With Audio Merge fallback)
dl_specific() {
  local url="$1"
  local f_id="$2"

  cd "$DIR_VIDEO" || exit
  echo -e "${BLUE}📂 Target: $DIR_VIDEO${NC}"

  # Logic: Download the Selected ID + Best Audio.
  # If the Selected ID already has audio (e.g. standard mp4), the /b fallback handles it.
  yt-dlp "${BASE_ARGS[@]}" \
    --download-archive "$HIST_VIDEO" \
    --merge-output-format mkv \
    -f "${f_id}+ba/b" \
    -o "%(title)s [%(id)s].%(ext)s" \
    "$url"
}

# 3. Audio Only Mode (MP3)
dl_audio() {
  local url="$1"
  cd "$DIR_MUSIC" || exit
  echo -e "${BLUE}📂 Target: $DIR_MUSIC${NC}"
  echo -e "${BLUE}🎵 Mode: AUDIO (MP3)${NC}"

  yt-dlp "${BASE_ARGS[@]}" \
    --download-archive "$HIST_MUSIC" \
    --extract-audio \
    --audio-format mp3 \
    --audio-quality 0 \
    -o "%(title)s.%(ext)s" \
    "$url"
}

# 4. Fallback: Quick Best (Old Behavior)
dl_best() {
  local url="$1"
  cd "$DIR_VIDEO" || exit
  echo -e "${BLUE}📂 Target: $DIR_VIDEO${NC}"
  echo -e "${BLUE}🚀 Mode: AUTO BEST${NC}"

  yt-dlp "${BASE_ARGS[@]}" \
    --download-archive "$HIST_VIDEO" \
    --merge-output-format mkv \
    -f "bv+ba/b" \
    -o "%(title)s [%(id)s].%(ext)s" \
    "$url"
}

# --- MAIN ROUTER ---
check_deps

if [[ -z "$1" ]]; then
  echo -e "${BLUE}Usage:${NC} archive <URL> [flags]"
  echo "  <URL>         Scan & Select Quality (Interactive)"
  echo "  -a <URL>      Quick Audio (MP3)"
  echo "  -b <URL>      Quick Best (Skip Menu)"
  exit 1
fi

# Flag Handling
case "$1" in
-a | --audio)
  dl_audio "$2"
  ;;
-b | --best)
  dl_best "$2"
  ;;
http* | www*)
  # If it looks like a URL, go straight to scan mode
  scan_and_select "$1"
  ;;
*)
  # Handle case where user puts flag after URL or messes up
  if [[ "$2" =~ ^http ]]; then
    scan_and_select "$2"
  else
    echo "Invalid usage."
    exit 1
  fi
  ;;
esac
