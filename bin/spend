#!/usr/bin/env python3
import sys
import datetime
import os
import subprocess

# --- CONFIGURATION ---
JOURNAL_FILE = os.path.expanduser("~/Documents/finance/2026.journal")
CURRENCY = "NGN"
DEFAULT_SOURCE = "Assets:Cash:Wallet"

# Keyword Triggers
SOURCE_TRIGGERS = {
    "opay": "Assets:Bank:Opay",
    "fb": "Assets:Bank:Firstbank",
    "card": "Assets:Bank:Firstbank",
}


def rofi_prompt():
    """Launch Rofi to get input if no args are provided."""
    try:
        # Prompt format: "AMOUNT CATEGORY [NOTE] [SOURCE]"
        cmd = [
            "rofi",
            "-dmenu",
            "-p",
            "💸 Spend",
            "-theme-str",
            "window {width: 500px;}",
        ]
        result = subprocess.run(
            cmd, input="", capture_output=True, text=True, check=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return None


def notify(message, urgent=False):
    urgency = "critical" if urgent else "normal"
    subprocess.run(["notify-send", "-u", urgency, "Fortress Spend", message])


def main():
    args = sys.argv[1:]

    # --- 1. DUAL MODE SWITCH ---
    if not args:
        # No args? Launch GUI!
        user_input = rofi_prompt()
        if not user_input:
            sys.exit(0)
        args = user_input.split()

    # --- 2. VALIDATION ---
    if len(args) < 2:
        print("Usage: spend <amount> <category> [description] [source]")
        notify("Invalid Input. Format: Amount Category Note", urgent=True)
        sys.exit(1)

    try:
        amount = float(args[0].replace(",", ""))
    except ValueError:
        notify("Error: First value must be a number.", urgent=True)
        sys.exit(1)

    # --- 3. PARSING ---
    # Category (First word after amount)
    raw_category = args[1].capitalize()
    target_account = f"Expenses:{raw_category}"

    # Logic to find Description and Source
    remaining_args = args[2:]
    source_account = DEFAULT_SOURCE

    # Check if the very last word is a source trigger (e.g., "opay")
    if remaining_args and remaining_args[-1].lower() in SOURCE_TRIGGERS:
        trigger = remaining_args.pop().lower()
        source_account = SOURCE_TRIGGERS[trigger]

    description = (
        " ".join(remaining_args) if remaining_args else f"Quick {raw_category}"
    )

    # --- 4. WRITE ENTRY ---
    today = datetime.date.today().strftime("%Y-%m-%d")

    entry = f"\n{today} * {description}\n"
    entry += f"    {target_account:<35} {amount:,.2f} {CURRENCY}\n"
    entry += f"    {source_account}\n"

    try:
        with open(JOURNAL_FILE, "a") as f:
            f.write(entry)

        # Feedback
        msg = f"💸 {amount:,.2f} on {raw_category} ({source_account.split(':')[-1]})"
        print(msg)
        notify(msg)

        # Update System
        os.system("pkill -RTMIN+9 waybar")
        subprocess.run(["mirror"])

    except Exception as e:
        notify(f"Write Error: {e}", urgent=True)


if __name__ == "__main__":
    main()
