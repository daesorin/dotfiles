#!/usr/bin/env python3
import subprocess
import sys
import os
import datetime
from rich.console import Console
from rich.table import Table
from rich.panel import Panel
from rich.bar import Bar
from rich import box

# --- CONFIGURATION ---
JOURNAL_FILE = os.path.expanduser("~/Documents/finance/2026.journal")
CURRENCY = "NGN"

console = Console()

def get_monthly_data():
    """Ask hledger for expenses this month, strictly categorized."""
    # We use depth 2 to see 'Food:Street' vs 'Food:Groceries'
    cmd = [
        "hledger", "-f", JOURNAL_FILE,
        "balance", "expenses",
        "--period", "this month",
        "--depth", "2",
        "--output-format", "csv",
        "--no-total"
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return result.stdout.strip().split("\n")
    except subprocess.CalledProcessError:
        console.print("[bold red]Error:[/bold red] Could not read journal.")
        sys.exit(1)

def parse_data(csv_lines):
    data = []
    total_spent = 0.0

    for line in csv_lines:
        if '"account"' in line or not line:
            continue
        
        parts = line.replace('"', "").split(",")
        if len(parts) < 2: 
            continue

        account = parts[0]
        # Skip the "Expenses" parent total if hledger outputs it
        if account == "Expenses": 
            continue

        try:
            # Clean "1,400.00 NGN" -> 1400.00
            raw_amount = parts[1].split(" ")[0].replace(",", "")
            amount = float(raw_amount)
        except ValueError:
            continue

        if amount > 0:
            data.append((account, amount))
            total_spent += amount

    # Sort: Highest spenders first
    data.sort(key=lambda x: x[1], reverse=True)
    return data, total_spent

def print_report(data, total):
    now = datetime.datetime.now()
    
    # 1. The Header
    console.print(Panel(
        f"[bold]MONTHLY ANALYSIS: {now.strftime('%B %Y').upper()}[/bold]", 
        style="blue", 
        expand=False
    ))

    if total == 0:
        console.print("[yellow]No spending recorded this month.[/yellow]")
        return

    # 2. The Table
    table = Table(box=box.SIMPLE, show_header=True, header_style="bold cyan")
    table.add_column("Category", style="white")
    table.add_column("Amount", justify="right", style="bold red")
    table.add_column("Dist", justify="right", style="dim")
    table.add_column("Visual", width=40)

    for account, amount in data:
        # Clean "Expenses:Food:Street" -> "Food:Street"
        name = account.replace("Expenses:", "")
        percent = (amount / total) * 100
        
        # Color Coding for "Bad" categories
        color = "green"
        if "Alcohol" in name or "Vices" in name:
            color = "red"
        elif "Street" in name:
            color = "yellow"

        # Create Bar
        bar = Bar(size=100, begin=0, end=percent, color=color, width=30)
        
        table.add_row(
            name, 
            f"{amount:,.2f}", 
            f"{percent:.1f}%", 
            bar
        )

    console.print(table)
    console.print(f"\n[bold]TOTAL OUTFLOW:[/bold] [bold red]{CURRENCY} {total:,.2f}[/bold red]\n")

if __name__ == "__main__":
    if not os.path.exists(JOURNAL_FILE):
        console.print(f"[bold red]Error:[/bold red] Journal not found at {JOURNAL_FILE}")
    else:
        raw = get_monthly_data()
        data, total = parse_data(raw)
        print_report(data, total)
