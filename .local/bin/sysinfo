#!/usr/bin/env bash

# ==============================================================================
#  SYSINFO - Arch Linux System Report
#  A comprehensive dashboard for hardware, network, and package status.
# ==============================================================================

# --- COLORS ---
GREEN='\033[1;32m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'
BOLD='\033[1m'

# --- HEADER ---
echo -e "${CYAN}=== ARCH LINUX SYSTEM INFORMATION ===${NC}"
echo ""

# --- SYSTEM OVERVIEW ---
# Extract pretty name (e.g., "Arch Linux")
OS_NAME=$(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)
KERNEL=$(uname -r)
# Get CPU model, remove duplicate spaces
CPU=$(grep "model name" /proc/cpuinfo | head -1 | cut -d':' -f2 | xargs)

echo -e "${GREEN}рџ’» OS:${NC}      $OS_NAME"
echo -e "${GREEN}рџђ§ Kernel:${NC}  $KERNEL"
echo -e "${GREEN}рџ§  CPU:${NC}     $CPU"
echo ""

# --- HARDWARE ---
echo -e "${CYAN}рџ“Љ Hardware Overview:${NC}"
echo "в”њв”Ђв”Ђ Architecture: $(uname -m)"
echo "в”њв”Ђв”Ђ CPU Cores:    $(nproc)"

# Memory usage calculation
MEM_TOTAL=$(free -h | awk '/^Mem:/ {print $2}')
MEM_USED=$(free -h | awk '/^Mem:/ {print $3}')
MEM_PERCENT=$(free | awk '/^Mem:/ {printf("%.1f"), $3/$2 * 100}')

echo "в”њв”Ђв”Ђ RAM Total:    $MEM_TOTAL"
echo "в”њв”Ђв”Ђ RAM Used:     $MEM_USED ($MEM_PERCENT%)"

# Disk usage (filtering for physical disks like /dev/sd* or /dev/nvme*)
echo "в”њв”Ђв”Ђ Disks:"
df -h | grep "^/dev/" | awk '{print "в”‚   в””в”Ђв”Ђ " $1 " (" $4 " free / " $2 " total)"}'

echo ""

# --- NETWORK ---
echo -e "${CYAN}рџЊђ Network:${NC}"
# Get IPs, ignore loopback
ip -4 addr show | grep "inet " | grep -v 127.0.0.1 | awk '{print "в”њв”Ђв”Ђ " $2 " (" $NF ")"}' | sed 's|/.* (|( |'

echo ""

# --- STATUS ---
echo -e "${CYAN}рџ“€ Status:${NC}"
UPTIME=$(uptime -p | sed 's/up //')
LOAD=$(uptime | awk -F'load average:' '{print $2}' | xargs)
PROCESSES=$(ps aux | wc -l)

echo "в”њв”Ђв”Ђ Uptime:       $UPTIME"
echo "в”њв”Ђв”Ђ Load Avg:     $LOAD"
echo "в”њв”Ђв”Ђ Processes:    $PROCESSES running"

echo ""

# --- PACKAGES ---
echo -e "${CYAN}рџ“¦ Packages:${NC}"
# Check if pacman exists (sanity check for non-Arch systems)
if command -v pacman &> /dev/null; then
    PKG_TOTAL=$(pacman -Q | wc -l)
    PKG_EXPLICIT=$(pacman -Qe | wc -l)
    # Check for AUR helper (paru/yay) or fallback to pacman foreign check
    PKG_AUR=$(pacman -Qm | wc -l)
    
    echo "в”њв”Ђв”Ђ Installed:    $PKG_TOTAL"
    echo "в”њв”Ђв”Ђ Explicit:     $PKG_EXPLICIT"
    echo "в”њв”Ђв”Ђ AUR:          $PKG_AUR"
else
    echo "в”њв”Ђв”Ђ Manager:      pacman not found"
fi

echo ""

# --- DESKTOP ENVIRONMENT ---
echo -e "${CYAN}рџ–јпёЏ  Desktop:${NC}"
echo "в”њв”Ђв”Ђ Session:      ${XDG_SESSION_TYPE:-unknown}"
echo "в”њв”Ђв”Ђ Desktop:      ${XDG_CURRENT_DESKTOP:-unknown}"
echo ""
