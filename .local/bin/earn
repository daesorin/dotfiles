#!/usr/bin/env python3
import subprocess
import datetime
import os
import sys

# --- CONFIGURATION ---
JOURNAL_FILE = os.path.expanduser("~/Documents/finance/2026.journal")
CURRENCY = "NGN"

# Default Defaults
DEFAULT_DESTINATION = "Assets:Bank:Firstbank"
DEFAULT_SOURCE = "Income:Unsorted"

# --- MAPPINGS ---
# Map shorthand codes to full Income Accounts
SOURCE_MAP = {
    "sal": "Income:Salary",
    "gig": "Income:Business",
    "gift": "Income:Gifts",
    "int": "Income:Interest",
    "refund": "Income:Refunds",
}

# Map keywords to Asset Accounts (Where the money lands)
DESTINATION_MAP = {
    "opay": "Assets:Bank:Opay",
    "cash": "Assets:Cash:Wallet",
    "wallet": "Assets:Cash:Wallet",
    "fb": "Assets:Bank:Firstbank",
}

def rofi_prompt():
    """Launch Rofi to get user input."""
    try:
        cmd = ["rofi", "-dmenu", "-p", "💰 Earn", "-theme-str", "window {width: 500px;}"]
        result = subprocess.run(cmd, input="", capture_output=True, text=True, check=True)
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return None  # User pressed Esc

def parse_input(raw_input):
    """
    Input format: "AMOUNT SOURCE NOTE [DESTINATION]"
    Example: "50000 gig Web Design opay"
    """
    parts = raw_input.split()
    if not parts:
        return None

    # 1. Amount (First token)
    try:
        amount = float(parts[0].replace(",", ""))
    except ValueError:
        notify("Error", "Invalid amount entered.")
        sys.exit(1)

    # 2. Source (Second token)
    source_key = parts[1].lower() if len(parts) > 1 else "misc"
    source_account = SOURCE_MAP.get(source_key, DEFAULT_SOURCE)

    # 3. Note & Destination detection
    # We scan the remaining words. If one matches a destination keyword, 
    # we pluck it out and use it as the destination.
    raw_note_parts = parts[2:] if len(parts) > 2 else ["Unspecified"]
    destination_account = DEFAULT_DESTINATION
    clean_note_parts = []

    for word in raw_note_parts:
        lower_word = word.lower()
        if lower_word in DESTINATION_MAP:
            destination_account = DESTINATION_MAP[lower_word]
        else:
            clean_note_parts.append(word)
    
    note = " ".join(clean_note_parts)

    return amount, source_account, destination_account, note

def write_journal(amount, source, dest, note):
    today = datetime.date.today().strftime("%Y-%m-%d")
    
    # Hledger Format:
    # 2026-01-01 * Note
    #     Assets:Bank      10,000 NGN
    #     Income:Source
    
    entry = f"\n{today} * {note}\n"
    entry += f"    {dest:<35} {amount:,.2f} {CURRENCY}\n"
    entry += f"    {source}\n"

    with open(JOURNAL_FILE, "a") as f:
        f.write(entry)

def notify(title, message, urgent=False):
    urgency = "critical" if urgent else "normal"
    subprocess.run(["notify-send", "-u", urgency, title, message])

def refresh_ui():
    # Signal Waybar to update
    os.system("pkill -RTMIN+9 waybar")
    # Optional: Run mirror to update any open terminals
    # subprocess.run(["mirror"]) 

def main():
    user_input = rofi_prompt()
    if not user_input:
        sys.exit(0)

    try:
        amount, source, dest, note = parse_input(user_input)
        write_journal(amount, source, dest, note)
        
        # Success
        notify("Income Recorded", f"💰 {CURRENCY} {amount:,.2f} -> {dest.split(':')[-1]}")
        refresh_ui()

    except Exception as e:
        notify("Fortress Error", str(e), urgent=True)

if __name__ == "__main__":
    main()
